      SELECT b."Id", b."AprovedById", b."BasePrice", b."BookingDate", b."BrideIdDocumentDataUrl", b."BridegroomIdDocumentDataUrl", b."CreatedAt", b."EndTime", b."EventTypeId", b."GuestsCount", b."ReminderSent", b."ServicesPrice", b."StartTime", b."Status", b."TotalPrice", b."UpdatedAt", b."UserId", b."VenueId", u."Id", u."CreatedAt", u."Email", u."FirstName", u."IsActive", u."LastName", u."PasswordHash", u."PhoneNumber", u."RoleId", u."SecondaryPhoneNumber", u."UpdatedAt", v."Id", v."Address", v."Capacity", v."Category", v."City", v."CompanyId", v."CreatedAt", v."Description", v."IsActive", v."Name", v."PricePerHour", v."PricingType", v."UpdatedAt"
      FROM "Bookings" AS b
      INNER JOIN "Users" AS u ON b."UserId" = u."Id"
      INNER JOIN "Venues" AS v ON b."VenueId" = v."Id"
      WHERE b."Status" = 'Confirmed' AND NOT (b."ReminderSent") AND b."BookingDate" >= @fromUtc AND b."BookingDate" <= @toUtc
